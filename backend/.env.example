# Supported values: local, test, staging, production.
# Staging/production require HTTPS origins, a 32+ character secret,
# AUTO_CREATE_TABLES=false, a non-SQLite database, LOG_FORMAT=json,
# and DOCKER_LOGS_ENABLED=false.
APP_ENV=local
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:3100
LOG_LEVEL=INFO
LOG_FORMAT=console
DOCKER_LOGS_ENABLED=true
METRICS_ENABLED=true

SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

DATABASE_URL=postgresql+psycopg://equipment_agent:equipment_agent@postgres:5432/equipment_agent
AUTO_CREATE_TABLES=true

GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin-password

CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_PROVIDER=hashing
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
HASHING_EMBEDDING_DIMENSIONS=256
TOP_K_TEXT=5
TOP_K_IMAGES=3
RETRIEVAL_MODE=hybrid
RETRIEVAL_CANDIDATE_MULTIPLIER=4
LEXICAL_CANDIDATE_LIMIT=1000
RECIPROCAL_RANK_FUSION_K=60
MAX_REVISION_LOOPS=1
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_SIZE_MB=50
MAX_PDF_PAGES=1000
MAX_UPLOAD_FILENAME_LENGTH=255
INGESTION_MODE=inline
INGESTION_MAX_ATTEMPTS=3
INGESTION_POLL_SECONDS=2
INGESTION_JOB_TIMEOUT_MINUTES=30
IMAGE_DIR=./data/images
TRACE_DIR=./data/traces
